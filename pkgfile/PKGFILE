pkgname=voidbr-packettracer
pkgdesc="A cross-platform visual simulation tool designed by Cisco Systems that allows users to create network topologies and imitate modern computer network"
pkgver=9.0.0
pkgrel=1
arch=('x86_64')
license=('custom:Cisco-EULA')
url="https://github.com/voidlinuxbr/$pkgname"
provides=()
#depends=(alsa-lib	gtk3 libcups libxss libxtst nss ttf-liberation xdg-utils)
options=('!emptydirs' '!strip')
source=(
  https://www.voidbr.org/iso/cisco/CiscoPacketTracer_900_Ubuntu_64bit.deb
  CiscoPacketTracer-9.0.0.desktop
  CiscoPacketTracerPtsa-9.0.0.desktop
)

makedepends=(bsdtar)

package() {
	local dirs=("usr" "etc" "opt")
	#echo "DESTDIR=$DESTDIR"
	#echo "pkgdir=$pkgdir"
	#echo "srcdir=$srcdir"
	#echo "_pkgsrc=$_pkgsrc"

	cd ${srcdir}/
	for dir in "${dirs[@]}"; do
		if [ -d "${_pkgsrc}/${dir}" ]; then
			cp -a "${_pkgsrc}/${dir}" "$DESTDIR/"
		fi
	done

	echo $pkgdir
	bsdtar -xf data.tar.xz -C "$pkgdir/"

  mkdir -p $pkgdir/usr/share/applications/
	install -Dm644 CiscoPacketTracer-9.0.0.desktop $pkgdir/usr/share/applications/
	install -Dm644 CiscoPacketTracerPtsa-9.0.0.desktop $pkgdir/usr/share/applications/

	# License
	#install -Dm644 "$pkgdir"/opt/google/chrome/WidevineCdm/LICENSE \
	#install -Dm644 eula_text.html "$pkgdir"/usr/share/licenses/google-chrome/eula_text.html
	#	"$pkgdir"/usr/share/licenses/google-chrome-$_channel/WidevineCdm-LICENSE.txt

}
